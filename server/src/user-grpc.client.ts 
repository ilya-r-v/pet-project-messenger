import { Injectable, OnModuleInit, Inject } from '@nestjs/common';
import { ClientGrpc } from '@nestjs/microservices';
import { Observable, firstValueFrom } from 'rxjs';
import { USER_SERVICE_GRPC } from './grpc-client.module';

interface UserGrpcService {
  getUser(request: { id: string }): Observable<{
    id: string;
    email: string;
    firstName: string;
    lastName: string;
    createdAt: string;
  }>;
  getUsersBatch(request: { ids: string[] }): Observable<{
    users: Array<{ id: string; email: string; firstName: string; lastName: string }>;
  }>;
  userExists(request: { id: string }): Observable<{ exists: boolean }>;
}

@Injectable()
export class UserGrpcClient implements OnModuleInit {
  private userService!: UserGrpcService;

  constructor(
    @Inject(USER_SERVICE_GRPC) private client: ClientGrpc,
  ) {}

  onModuleInit() {
    this.userService = this.client.getService<UserGrpcService>('UserService');
  }

  async getUser(id: string) {
    return firstValueFrom(this.userService.getUser({ id }));
  }

  async getUsersBatch(ids: string[]) {
    const response = await firstValueFrom(
      this.userService.getUsersBatch({ ids })
    );
    return response.users;
  }

  async userExists(id: string): Promise<boolean> {
    const response = await firstValueFrom(
      this.userService.userExists({ id })
    );
    return response.exists;
  }
}